{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "tabWidth": 2,
  "printWidth": 80,
  "trailingComma": "none",
  "semi": true,
  "useTabs": false,
  "singleQuote": false,
  "bracketSpacing": true,
  "sortPackageJson": false,
  "ignorePatterns": [
    "coverage",
    "dist",
    "website/.next",
    "website/.docusaurus",
    "website/build"
  ]
}
